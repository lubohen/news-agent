# ════════════════════════════════════════════════════════════
#  News Agent — Configuração
#  Copie este arquivo: cp .env.example .env
#  Preencha os valores marcados com <ALTERE_AQUI>
# ════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────
# Evolution API — WhatsApp Self-Hosted
# ─────────────────────────────────────────────────────────────

# URL interna do container (não altere se usar o docker-compose padrão)
SERVER_URL=http://evolution-api:8080

# Tipo de autenticação (não altere)
AUTHENTICATION_TYPE=apikey

# Chave de acesso à API — crie uma string aleatória e segura
# Exemplo: openssl rand -hex 32
AUTHENTICATION_API_KEY=<ALTERE_AQUI_SUA_API_KEY_FORTE>

# Configuração de sessão
CONFIG_SESSION_PHONE_CLIENT=NewsAgent
CONFIG_SESSION_PHONE_NAME=Chrome

# ─── Banco de dados da Evolution API (PostgreSQL) ─────────────
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_CONNECTION_CLIENT_NAME=evolution_api
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# ─── Cache (in-memory, sem Redis) ─────────────────────────────
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# Outros
DEL_INSTANCE=false
LANGUAGE=pt-BR
LOG_LEVEL=ERROR,WARN,INFO,LOG


# ─────────────────────────────────────────────────────────────
# PostgreSQL — Banco de dados para Evolution API
# ─────────────────────────────────────────────────────────────
POSTGRES_DB=evolutiondb
POSTGRES_USER=evolution
POSTGRES_PASSWORD=<ALTERE_AQUI_SENHA_DO_BANCO>


# ─────────────────────────────────────────────────────────────
# WhatsApp — Destinatário
# ─────────────────────────────────────────────────────────────

# Nome da instância WhatsApp (pode deixar como está)
WHATSAPP_INSTANCE_NAME=news-agent

# Número que vai RECEBER as mensagens (com código do país + DDD)
# Ex: +5541999990000  ou  +5511988887777
WHATSAPP_RECIPIENT=+5511917121239


# ─────────────────────────────────────────────────────────────
# E-mail — Outlook SMTP
#
# Passo a passo para gerar App Password:
#   1. Acesse: https://account.microsoft.com/security
#   2. Ative "Verificação em duas etapas"
#   3. Vá em "Senhas de aplicativo" → crie uma para "News Agent"
#   4. Cole os caracteres gerados em EMAIL_APP_PASSWORD
# ─────────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp-mail.outlook.com
EMAIL_SMTP_PORT=587

# Seu endereço Outlook que vai ENVIAR o e-mail
EMAIL_SENDER=lubohen@outlook.com

# Senha de App do Outlook (veja README para gerar)
EMAIL_APP_PASSWORD=<ALTERE_AQUI_APP_PASSWORD>

# E-mail que vai RECEBER a newsletter
EMAIL_RECIPIENT=lubohen@outlook.com


# ─────────────────────────────────────────────────────────────
# Agente — Agendamento
# ─────────────────────────────────────────────────────────────

# Hora e minuto da execução diária
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Fuso horário (lista: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
SCHEDULE_TIMEZONE=America/Sao_Paulo

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
